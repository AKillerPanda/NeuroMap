# NeuroMap Backend Configuration
# Copy this file to .env and update values for your environment

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=0
# IMPORTANT: Generate a strong random key using: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use the default value in production!
SECRET_KEY=your-secret-key-here-change-in-production-use-command-above

# Server Configuration
# HOST=0.0.0.0 exposes the app on all interfaces (suitable for Docker/reverse-proxy)
# Use HOST=127.0.0.1 for local-only access without a reverse proxy
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# Performance
ENABLE_COMPRESSION=1
CACHE_TIMEOUT=3600
THREAD_POOL_SIZE=4

# Graph Generation
MAX_TOPICS_PER_SKILL=50
GRAPH_GENERATION_TI
# Enable rate limiting in production; disable for local/dev testing
RATELIMIT_ENABLED=1
# API Rate Limiting (optional)
RATELIMIT_ENABLED=0
RATELIMIT_REQUESTS_PER_MINUTE=60
